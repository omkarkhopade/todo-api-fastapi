TODO_API_DATABASE_URL=sqlite:///./todo.db
TODO_API_SECRET_KEY=replace-with-at-least-32-random-characters
TODO_API_ACCESS_TOKEN_EXPIRE_MINUTES=30
TODO_API_DEBUG=false
TODO_API_CORS_ORIGINS=["http://localhost:3000"]
TODO_API_LOG_LEVEL=INFO

# Optional SMTP settings. Leave blank to disable email delivery.
TODO_API_SMTP_SERVER=smtp.gmail.com
TODO_API_SMTP_PORT=587
TODO_API_SMTP_USER=
TODO_API_SMTP_PASSWORD=
TODO_API_FROM_EMAIL=
TODO_API_SMTP_USE_TLS=false
TODO_API_SMTP_START_TLS=true
